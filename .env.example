# ──────────────────────────────────────────────
# Now & Always Construction — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────

# Site URL (used for SEO, sitemap, canonical URLs, Open Graph)
NEXT_PUBLIC_SITE_URL=https://nowandalways.co.za

# Social Media Links (leave as # if not yet set up)
NEXT_PUBLIC_SOCIAL_FACEBOOK=#
NEXT_PUBLIC_SOCIAL_INSTAGRAM=#
NEXT_PUBLIC_SOCIAL_LINKEDIN=#

# ──────────────────────────────────────────────
# OPTIONAL: Backend Integration
# ──────────────────────────────────────────────
# If you add a server-side form handler later, configure these:
# DATABASE_URL=file:./dev.db
# SMTP_HOST=smtp.your-provider.co.za
# SMTP_PORT=587
# SMTP_USER=projects@nowandalways.co.za
# SMTP_PASS=your-email-password
# FORM_RECIPIENT=projects@nowandalways.co.za
